{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["unicorn", "typescript", "oxc"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn"
  },
  "rules": {
    "typescript/no-explicit-any": "off",
    "no-unused-vars": "warn"
  },
  "env": {
    "node": true,
    "es2024": true
  },
  "ignorePatterns": ["dist", "node_modules", "assets"]
}
